# Core
PORT=3000
DB_URL=mongodb://127.0.0.1:27017/callAnalyzer
JWT_SECRET=changeme
JWT_EXP=1d

# Worker retry policy
WORKER_MAX_RETRIES=3
WORKER_RETRY_BASE_MS=2000

# Service endpoints when backend runs on host machine
WHISPER_URL=http://localhost:9000
OLLAMA_URL=http://localhost:11434
RABBITMQ_URL=amqp://admin:admin@localhost:5672

