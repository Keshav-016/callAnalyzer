# Example environment variables for backend
PORT=3000
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCP_PROJECT_ID=your-project-id
STORAGE_BUCKET=your-audio-bucket
GCP_PUBSUB_TOPIC=audio-upload-events
GCP_PUBSUB_SUBSCRIPTION=transcription-worker-sub
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=call_analyzer
JWT_SECRET=changeme
JWT_EXP=1d
